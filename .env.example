# Terminal3 Agent Auth SDK
# Get this from the Terminal3 claim page. Never expose it to client-side code.
T3N_API_KEY=

# Optional: "testnet" or "production". Defaults to testnet.
T3N_ENVIRONMENT=testnet

# Optional: numeric Terminal3 contract id used for private evidence map access.
T3N_CONTRACT_ID=

# Optional: tenant script name for live audit event execution.
# Example: z:<tenant-tail>:skillproof-contracts
T3N_SKILLPROOF_SCRIPT=
T3N_SKILLPROOF_AUDIT_FUNCTION=record-audit-event

# Optional demo DID shown when no T3N_API_KEY is configured.
T3N_DEMO_DID=did:t3n:8f23d4a64f20e935b86c1f0e5a7f91a4

# Optional: enables live AI grading for the interview flow.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional future persistence/storage hooks.
MONGODB_URI=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
